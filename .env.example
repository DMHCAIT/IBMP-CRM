# =============================================================================
# IBMP CRM — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
#
# Generate JWT_SECRET_KEY:
#   openssl rand -hex 32
# =============================================================================

# ── Authentication ─────────────────────────────────────────────────────────
JWT_SECRET_KEY=REPLACE_ME_openssl_rand_-hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Supabase ───────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY

# ── Database (SQLite fallback for local dev without Supabase) ─────────────
# DATABASE_URL=sqlite:///./ibmp_crm.db

# ── AI / OpenAI ────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── WhatsApp (Interakt) ────────────────────────────────────────────────────
INTERAKT_API_KEY=

# ── Frontend origin (CORS) ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Google Sheets (optional) ───────────────────────────────────────────────
# GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ── Redis (set automatically by docker-compose, override for hosted Redis) ──
# REDIS_URL=redis://localhost:6379/0

# ── Runtime ────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=DEBUG
PORT=8000

# ── Sentry (optional error monitoring) ────────────────────────────────────
# SENTRY_DSN=https://xxx@sentry.io/xxx
